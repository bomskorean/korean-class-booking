// 馬賑韓国語教室 予約システム — データモデル (SQLite 開発版)
// SQLite は enum・Json 非対応のため String に統一。
// 本番(PostgreSQL)移行時は provider を "postgresql" に戻し、
// String の enum フィールドを enum 型に置き換える。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enum 値の定数コメント（SQLite では String で保存） ──────────────────────
// Role              : STUDENT | ADMIN
// NotifyChannel     : EMAIL | LINE | BOTH
// Lang              : JA | KO
// CourseType        : REGULAR | SHORT | TOPIK | STUDY_ABROAD
// LessonMode        : OFFLINE | ONLINE | BOTH
// BookingType       : TRIAL | REGULAR
// BookingStatus     : CONFIRMED | CANCELLED | CHANGED | COMPLETED | NO_SHOW
// SlotStatus        : OPEN | CLOSED | FULL | BLOCKED_BY_CALENDAR
// TicketStatus      : ACTIVE | EXPIRED | USED_UP
// TicketSource      : PAYMENT | MANUAL
// PaymentMethod     : STRIPE_CARD | PAYPAY | OFFLINE
// PaymentStatus     : PENDING | PAID | REFUNDED
// Attendance        : PRESENT | ABSENT | LATE
// RefundStatus      : REQUESTED | APPROVED | PAID

model User {
  id                String   @id @default(cuid())
  role              String   @default("STUDENT")
  name              String
  email             String   @unique
  phone             String?
  lineUserId        String?  @unique
  preferredLang     String   @default("JA")
  notifyChannel     String   @default("BOTH")
  noShowCount       Int      @default(0)
  lateCancelCount   Int      @default(0)
  bookingRestricted Boolean  @default(false)
  createdAt         DateTime @default(now())

  tickets    UserTicket[]
  bookings   Booking[]
  payments   Payment[]
  progress   ProgressLog[]
  trials     TrialIntake[]
  agreements Agreement[]
  refunds    Refund[]
}

model Course {
  id          String  @id @default(cuid())
  type        String  // CourseType
  titleJa     String
  titleKo     String?
  description String?
  level       String?
  lessonCount Int?
  imageUrl    String?
  isActive    Boolean @default(true)

  slots Slot[]
}

model TicketPackage {
  id             String  @id @default(cuid())
  name           String
  totalCount     Int
  price          Int
  unitPrice      Int
  listPrice      Int     @default(4000)
  validMonths    Int
  validFromBasis String  @default("first_lesson")
  courseScope    String?

  tickets UserTicket[]
}

model UserTicket {
  id             String    @id @default(cuid())
  userId         String
  packageId      String
  remainingCount Int
  heldCount      Int       @default(0)
  freeChangeUsed Boolean   @default(false)
  validFrom      DateTime?
  expiresAt      DateTime?
  status         String    @default("ACTIVE")   // TicketStatus
  source         String    @default("PAYMENT")  // TicketSource
  createdAt      DateTime  @default(now())

  user     User          @relation(fields: [userId],    references: [id])
  package  TicketPackage @relation(fields: [packageId], references: [id])
  bookings Booking[]
}

model Slot {
  id              String   @id @default(cuid())
  courseId        String
  teacherId       String?
  startAt         DateTime
  displayEndAt    DateTime
  blockEndAt      DateTime
  displayDuration Int      @default(50)
  blockDuration   Int
  capacity        Int      @default(1)
  bookedCount     Int      @default(0)
  mode            String   @default("BOTH")  // LessonMode
  location        String?
  onlineUrl       String?
  gcalEventId     String?
  status          String   @default("OPEN")  // SlotStatus

  course   Course    @relation(fields: [courseId], references: [id])
  bookings Booking[]
}

model Booking {
  id           String    @id @default(cuid())
  userId       String
  slotId       String
  type         String    // BookingType: TRIAL | REGULAR
  status       String    @default("CONFIRMED")  // BookingStatus
  usedTicketId String?
  createdAt    DateTime  @default(now())
  cancelledAt  DateTime?

  user       User        @relation(fields: [userId],       references: [id])
  slot       Slot        @relation(fields: [slotId],       references: [id])
  usedTicket UserTicket? @relation(fields: [usedTicketId], references: [id])
  progress   ProgressLog[]
}

model TrialIntake {
  id             String   @id @default(cuid())
  bookingId      String?
  userId         String?
  studyPeriod    String
  motivations    String   // JSON: string[]
  experience     String
  textbooks      String   @default("[]")  // JSON: string[]
  selfLevel      String?
  preferredMode  String?
  goalText       String?
  referralSource String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Payment {
  id                    String    @id @default(cuid())
  userId                String
  packageId             String?
  amount                Int
  method                String    // PaymentMethod
  status                String    @default("PENDING")  // PaymentStatus
  stripePaymentIntentId String?
  paidAt                DateTime?

  user User @relation(fields: [userId], references: [id])
}

model ProgressLog {
  id          String   @id @default(cuid())
  userId      String
  bookingId   String?
  attendance  String   @default("PRESENT")  // Attendance
  levelStage  String?
  teacherNote String?
  homework    String?
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId],    references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  channel   String
  payload   String?  // JSON text (本番PostgreSQLでは Json? に戻す)
  status    String   @default("sent")
  sentAt    DateTime @default(now())
}

model Agreement {
  id              String   @id @default(cuid())
  userId          String
  contractVersion String
  agreedAt        DateTime @default(now())
  ip              String?
  pdfUrl          String?

  user User @relation(fields: [userId], references: [id])
}

model Refund {
  id            String    @id @default(cuid())
  userId        String
  userTicketId  String?
  usedCount     Int
  settledAmount Int
  cancelFee     Int       @default(0)
  transferFee   Int       @default(0)
  refundAmount  Int
  status        String    @default("REQUESTED")  // RefundStatus
  processedAt   DateTime?

  user User @relation(fields: [userId], references: [id])
}
